      "cell_type": "code",
      "source": [
        "def main():\n",
        "    i = int(input('Início: '))\n",
        "    f = int(input('\\nFim: '))\n",
        "    s = 0\n",
        "    for c in range(i, f + 1):\n",
        "        s += c\n",
        "    print(f'\\nA soma entre {i} e {f} é igual a {s}')\n",
        "\n",
        "main()"
